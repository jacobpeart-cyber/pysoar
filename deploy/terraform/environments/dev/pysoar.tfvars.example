# PySOAR Terraform Variables
# Add these to your terraform.tfvars file (never commit terraform.tfvars!)

# Your EC2 key pair name (create one in AWS Console → EC2 → Key Pairs)
pysoar_key_pair_name = "pysoar-key"

# Restrict SSH to your IP only (find yours at whatismyip.com)
pysoar_ssh_allowed_cidrs = ["YOUR_IP_ADDRESS/32"]

# Admin login credentials
pysoar_admin_email    = "admin@yourdomain.com"
pysoar_admin_password = "ChangeThisStrongPassword123!"

# Generate these with: python -c "import secrets; print(secrets.token_urlsafe(64))"
pysoar_secret_key     = "GENERATE_A_STRONG_RANDOM_SECRET"
pysoar_jwt_secret_key = "GENERATE_A_DIFFERENT_STRONG_RANDOM_SECRET"
pysoar_db_password    = "GENERATE_A_STRONG_DB_PASSWORD"
